            hold-trigger-key-positions = <LEFT_HRM_TRIGGERS>;
            hold-trigger-on-release; };

        /* ── Left ring bilateral cross-variants ── */

        lR_p: lR_p { compatible = "zmk,behavior-hold-tap"; #binding-cells = <2>;
            tapping-term-ms = <240>; bindings = <&kp>, <&lR_tap>;
            flavor = "tap-preferred"; quick-tap-ms = <300>;
