        rM: rM { compatible = "zmk,behavior-hold-tap"; #binding-cells = <2>;
            tapping-term-ms = <210>; bindings = <&rM_hold>, <&kp>;
            flavor = "tap-preferred"; quick-tap-ms = <300>;
            require-prior-idle-ms = <150>;
